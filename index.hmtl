<script>
    // ====================== 核心功能：iOS 18及以上版本拦截 ======================
    (function checkiOSVersion() {
        const userAgent = navigator.userAgent;
        // 判断是否是iOS设备
        if (/iPhone|iPad|iPod/.test(userAgent)) {
            // 匹配iOS版本号
            const iosVersionMatch = userAgent.match(/OS (\d+)_/);
            if (iosVersionMatch) {
                const majorVersion = parseInt(iosVersionMatch[1]);
                // iOS 18及以上：拦截访问
                if (majorVersion >= 18) {
                    document.getElementById('mainContent').style.display = 'none';
                    document.getElementById('iosBlocked').style.display = 'flex';
                    return;
                }
            }
        }
        // 非iOS18+：正常加载所有功能
        initNormalFunctions();
    })();

    // 正常页面功能初始化
    function initNormalFunctions() {
        // FAQ 切换
        const faqItems = document.querySelectorAll('.faq-item');
        faqItems.forEach(item => {
            item.addEventListener('click', () => {
                item.classList.toggle('active');
            });
        });

        // 双语切换
        const langSwitch = document.querySelector('.lang-switch');
        const enTexts = document.querySelectorAll('.en-text');
        langSwitch.addEventListener('click', () => {
            enTexts.forEach(text => {
                text.style.display = text.style.display === 'none' ? 'block' : 'none';
            });
        });

        // 福利弹窗 + 注册表单逻辑
        const modal = document.getElementById('bonusModal');
        const closeModal = document.getElementById('closeModal');
        const bonusForm = document.getElementById('bonusForm');
        const successMsg = document.getElementById('successMsg');

        // 3秒自动弹出
        setTimeout(() => {
            modal.style.display = 'flex';
        }, 3000);

        // 关闭弹窗
        closeModal.addEventListener('click', () => {
            modal.style.display = 'none';
        });
        modal.addEventListener('click', (e) => {
            if(e.target === modal) modal.style.display = 'none';
        });

        // 表单提交
        bonusForm.addEventListener('submit', (e) => {
            e.preventDefault();
            bonusForm.style.display = 'none';
            successMsg.style.display = 'block';
            
            // 2秒后自动关闭弹窗
            setTimeout(() => {
                modal.style.display = 'none';
            }, 2000);
        });
    }
</script>
</body>
</html>
